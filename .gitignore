# =========================
# Terraform
# =========================

*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Ignore terraform directories
**/.terraform/*
.terraform/

# Ignore terraform lock backup files
.terraform.lock.hcl.backup

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore variable files containing secrets
*.tfvars
*.tfvars.json

# Exception for sample variable files
!*.example.tfvars

# Ignore plan files
*.tfplan
plan.out

# Ignore CLI config files
.terraformrc
terraform.rc

